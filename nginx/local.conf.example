# Local HTTP-only nginx config (no SSL, no domain names)
# Copy to local.conf — no changes needed, works as-is for local dev.
#
# Element:       http://localhost
# Matrix API:    http://localhost/matrix/ (proxied) or http://localhost:8008 directly
# Synapse Admin: http://localhost/synapse-admin/ (legacy: http://localhost:8080 redirects)
# Element Admin: http://localhost/element-admin/

server {
    listen 80;
    server_name localhost;

    # Synapse Admin (served under a path)
    location = /synapse-admin {
        return 301 /synapse-admin/;
    }

    location /synapse-admin/ {
        proxy_pass http://synapse-admin:8080/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto http;
        proxy_set_header Accept-Encoding "";
        sub_filter_types text/html;
        sub_filter_once off;
        sub_filter 'src="/' 'src="/synapse-admin/';
        sub_filter 'href="/' 'href="/synapse-admin/';
        # Rewrite redirect Location headers from the upstream so that the
        # /synapse-admin/ prefix is NOT lost when static-web-server adds a
        # trailing slash (e.g.  /auth-callback → /auth-callback/).
        proxy_redirect / /synapse-admin/;
    }

    # Element Admin (served under a path)
    location = /element-admin {
        return 301 /element-admin/;
    }

    location /element-admin/ {
        proxy_pass http://element-admin:8080/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto http;
        proxy_set_header Accept-Encoding "";
        sub_filter_types text/html;
        sub_filter_once off;
        sub_filter 'src="/' 'src="/element-admin/';
        sub_filter 'href="/' 'href="/element-admin/';
        proxy_redirect / /element-admin/;
    }

    # Element web app
    location / {
        proxy_pass http://element:80;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto http;
    }

    # MAS (Matrix Authentication Service)
    location /_mas/ {
        proxy_pass http://mas:8090;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto http;
    }

    # Synapse matrix API (so Element can reach it on same origin)
    location /_matrix/ {
        proxy_pass http://synapse:8008;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto http;
        client_max_body_size 300M;
    }

    location /_synapse/ {
        proxy_pass http://synapse:8008;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto http;
    }
}

# Synapse Admin
server {
    listen 8080;
    server_name localhost;

    # Legacy port: redirect to the canonical path.
    return 301 http://localhost/synapse-admin/;
}
