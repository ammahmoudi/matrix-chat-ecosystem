# Production nginx config — copy to default.conf and replace all occurrences of:
#   chat.example.com   → your Element/chat subdomain
#   matrix.example.com → your Matrix server domain
#   auth.example.com   → your MAS auth subdomain
#   push.example.com   → your ntfy push subdomain
#   cinny.chat.example.com → your Cinny subdomain (optional)
#
# SSL certificates are expected at /etc/letsencrypt/live/<domain>/
# (e.g. obtained via Certbot or copied into ssl-certs/).

# 1. ELEMENT WEB APP - HTTP (chat.example.com)
server {
    listen 80;
    server_name chat.example.com;

    # Hard-intercept the mobile guide redirect
    location /mobile_guide/ {
        return 302 /;
    }

    location /favicon.ico {
        proxy_pass http://element:80/images/logo.png;
    }

    location / {
        proxy_pass http://element:80;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto http;
        add_header Set-Cookie "element_mobile_redirect_to_guide=false; Path=/; Max-Age=31536000";
        proxy_set_header Accept-Encoding "";
        sub_filter '</head>' '<style>.mx_AuthFooter{display:flex!important;flex-wrap:wrap;justify-content:center;gap:0.4rem;padding:0.5rem 1rem}.mx_AuthFooter a{font-size:0.78rem}</style></head>';
        sub_filter_once on;
    }
}

# CINNY WEB APP - HTTP (cinny.chat.example.com) → redirect to HTTPS
server {
    listen 80;
    listen [::]:80;
    server_name cinny.chat.example.com;

    location / {
        return 301 https://$host$request_uri;
    }

    location /.well-known/acme-challenge/ {
        alias /var/lib/letsencrypt/.well-known/acme-challenge/;
    }
}

# FLUFFYCHAT WEB APP - HTTP (fluffy.chat.example.com) → redirect to HTTPS
server {
    listen 80;
    listen [::]:80;
    server_name fluffy.chat.example.com;

    location / {
        return 301 https://$host$request_uri;
    }

    location /.well-known/acme-challenge/ {
        alias /var/lib/letsencrypt/.well-known/acme-challenge/;
    }
}

# 2. MATRIX SERVER API - HTTP (matrix.example.com)
server {
    listen 80;
    server_name matrix.example.com;

    client_max_body_size 300M;

    location /.well-known/matrix/client {
        default_type application/json;
        add_header Access-Control-Allow-Origin *;
        return 200 '{"m.homeserver":{"base_url":"https://matrix.example.com"},"org.matrix.msc2965.authentication":{"issuer":"https://auth.example.com/","account":"https://auth.example.com/account"},"default_push_gateway":"https://push.example.com","org.unifiedpush.custom_gateway":"https://push.example.com","m.push":{"base_url":"https://push.example.com"}}';
    }

    location /.well-known/matrix/server {
        default_type application/json;
        add_header Access-Control-Allow-Origin *;
        return 200 '{"m.server":"matrix.example.com:443"}';
    }

    location = /synapse-admin {
        return 301 https://$host/synapse-admin/;
    }

    location /synapse-admin/ {
        return 301 https://$host$request_uri;
    }

    location / {
        proxy_pass http://synapse:8008;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto http;
    }
}

# 5. MAS AUTH - HTTP (auth.example.com) — redirect to HTTPS
server {
    listen 80;
    server_name auth.example.com;
    return 301 https://$host$request_uri;
}

# 7. PUSH (push.example.com) - HTTP redirect to HTTPS
server {
    listen 80;
    server_name push.example.com;
    return 301 https://$host$request_uri;
}

# 8. PUSH (push.example.com) - HTTPS → ntfy
server {
    listen 443 ssl;
    server_name push.example.com;

    ssl_certificate /etc/letsencrypt/live/push.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/push.example.com/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;

    resolver 127.0.0.11 valid=30s ipv6=off;

    # ntfy requires these for long-polling and WebSockets
    location / {
        set $ntfy_upstream http://ntfy:80;
        proxy_pass $ntfy_upstream;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_read_timeout 3600s;   # keep long-poll connections alive
    }
}

# 3. ELEMENT WEB APP - HTTPS (chat.example.com)
server {
    listen 443 ssl;
    server_name chat.example.com;

    ssl_certificate /etc/letsencrypt/live/chat.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/chat.example.com/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;

    # Hard-intercept the mobile guide redirect
    location /mobile_guide/ {
        return 302 /;
    }

    location /favicon.ico {
        proxy_pass http://element:80/images/logo.png;
    }

    location / {
        proxy_pass http://element:80;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        add_header Set-Cookie "element_mobile_redirect_to_guide=false; Path=/; Max-Age=31536000";
        proxy_set_header Accept-Encoding "";
        sub_filter '</head>' '<style>.mx_AuthFooter{display:flex!important;flex-wrap:wrap;justify-content:center;gap:0.4rem;padding:0.5rem 1rem}.mx_AuthFooter a{font-size:0.78rem}</style></head>';
        sub_filter_once on;
    }
}

# 3. MATRIX SERVER API (matrix.example.com)
server {
    listen 443 ssl;
    server_name matrix.example.com;

    ssl_certificate /etc/letsencrypt/live/matrix.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/matrix.example.com/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;

    client_max_body_size 300M;

    # Use Docker's internal DNS so upstream hostnames resolve dynamically at
    # request time — nginx won't crash at startup if a container isn't up yet
    resolver 127.0.0.11 valid=30s ipv6=off;

    # Well-known — advertise MAS as the OIDC issuer (required by Element X)
    location /.well-known/matrix/client {
        default_type application/json;
        add_header Access-Control-Allow-Origin *;
        return 200 '{"m.homeserver":{"base_url":"https://matrix.example.com"},"org.matrix.msc2965.authentication":{"issuer":"https://auth.example.com/","account":"https://auth.example.com/account"},"default_push_gateway":"https://push.example.com","org.unifiedpush.custom_gateway":"https://push.example.com","m.push":{"base_url":"https://push.example.com"}}';
    }

    location /.well-known/matrix/server {
        default_type application/json;
        add_header Access-Control-Allow-Origin *;
        return 200 '{"m.server":"matrix.example.com:443"}';
    }

    # Legacy /_mas/ path — redirect to new auth subdomain
    location /_mas/ {
        return 301 https://auth.example.com$request_uri;
    }

    # MAS Admin Panel
    location /mas-admin/ {
        set $mas_admin_upstream http://mas-admin:80;
        proxy_pass $mas_admin_upstream;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
    }

    # Synapse Admin Panel
    location = /synapse-admin {
        return 301 /synapse-admin/;
    }

    location /synapse-admin/ {
        set $synapse_admin_upstream http://synapse-admin:8080;
        proxy_pass $synapse_admin_upstream/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        # Rewrite redirect Location headers from the upstream so that the
        # /synapse-admin/ prefix is NOT lost when static-web-server adds a
        # trailing slash (e.g.  /auth-callback → /auth-callback/).
        # Without this, the OIDC auth-callback redirect lands on Synapse
        # instead of synapse-admin, causing the UI to freeze on login.
        proxy_redirect / /synapse-admin/;
    }

    # Legacy login/logout/refresh — must be handled by MAS, not Synapse
    location ~ ^/_matrix/client/(v3|r0)/(login|logout|logout/all|refresh) {
        set $mas_upstream http://mas:8090;
        proxy_pass $mas_upstream;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
    }

    location / {
        proxy_pass http://synapse:8008;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
    }
}

# 5. MAS AUTH - HTTPS (auth.example.com)
server {
    listen 443 ssl;
    server_name auth.example.com;

    ssl_certificate /etc/letsencrypt/live/auth.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/auth.example.com/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;

    resolver 127.0.0.11 valid=30s ipv6=off;

    location /api/ {
        set $mas_upstream http://mas:8090;

        # Handle CORS preflight
        if ($request_method = OPTIONS) {
            add_header Access-Control-Allow-Origin "https://matrix.example.com";
            add_header Access-Control-Allow-Methods "GET, POST, PUT, DELETE, PATCH, OPTIONS";
            add_header Access-Control-Allow-Headers "Authorization, Content-Type";
            add_header Access-Control-Max-Age 86400;
            return 204;
        }

        proxy_pass $mas_upstream;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_hide_header Access-Control-Allow-Origin;
        proxy_hide_header Access-Control-Allow-Headers;
        add_header Access-Control-Allow-Origin "https://matrix.example.com" always;
        add_header Access-Control-Allow-Headers "Authorization, Content-Type" always;
    }

    location / {
        set $mas_upstream http://mas:8090;
        proxy_pass $mas_upstream;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
    }
}

# CINNY WEB APP - HTTPS (cinny.chat.example.com)
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name cinny.chat.example.com;

    ssl_certificate /etc/letsencrypt/live/chat.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/chat.example.com/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;

    # Cache static assets; Cinny's internal nginx handles SPA routing
    location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff2?|ttf|eot)$ {
        proxy_pass http://cinny:80;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto https;
        expires 1y;
        add_header Cache-Control "public, immutable";
    }

    location / {
        proxy_pass http://cinny:80;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
    }
}

# FLUFFYCHAT WEB APP - HTTPS (fluffy.chat.example.com)
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name fluffy.chat.example.com;

    # Requires a wildcard cert for *.chat.example.com, or add fluffy.chat.example.com
    # as an alt-name when issuing the chat.example.com certificate.
    ssl_certificate /etc/letsencrypt/live/chat.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/chat.example.com/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;

    location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff2?|ttf|eot)$ {
        proxy_pass http://fluffychat-web:80;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto https;
        expires 1y;
        add_header Cache-Control "public, immutable";
    }

    location / {
        proxy_pass http://fluffychat-web:80;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
    }
}

# 6. SYNAPSE ADMIN DASHBOARD (legacy: matrix.example.com:8080 → redirects)
server {
    listen 8080;
    server_name matrix.example.com;

    # Legacy port: redirect to the canonical path.
    return 301 https://matrix.example.com/synapse-admin/;
}
