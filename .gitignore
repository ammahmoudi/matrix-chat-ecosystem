# (typo folder) - keep out of git
repo-soruces/

# Offline artifacts (keep docs/structure, but never commit large bundles)
artifacts/docker-images/*
artifacts/docker-archives/*
artifacts/tmp/*
# Local-only large files (kept for offline context)
spec.json

# Local debugging logs
submodule-add.log

# Legacy local source folders (use repo-sources/ instead)
synapse-src/
element-web-src/
repo-sources/
ssl-certs/