# LiveKit SFU configuration for matrix.mamood.ir
# https://docs.livekit.io/realtime/self-hosting/deployment/
#
# Secrets (LIVEKIT_KEY, LIVEKIT_SECRET) are set in docker-compose via
# environment variables. This file only contains structural / network config.

port: 7880

bind_addresses:
  - "0.0.0.0"

rtc:
  tcp_port: 7881
  # UDP media port range — open these in your firewall
  port_range_start: 50100
  port_range_end: 50200
  # Let LiveKit auto-detect the public IP (queries api.ipify.org at startup)
  use_external_ip: true

# TURN: handled by coturn — disable LiveKit's built-in TURN to avoid conflict
turn:
  enabled: false

# API key / secret — must match LIVEKIT_KEY and LIVEKIT_SECRET in .env
keys:
  YOUR_LIVEKIT_KEY: YOUR_LIVEKIT_SECRET
