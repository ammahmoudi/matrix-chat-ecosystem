# coturn TURN server configuration for matrix.mamood.ir
# Secrets are injected via the TURN_SECRET environment variable at startup.
# Run coturn with: docker compose up -d coturn

# --- Listeners ---
listening-port=3478
tls-listening-port=5349

# --- TLS (use the same cert as matrix.mamood.ir) ---
cert=/etc/ssl/turn/fullchain.pem
pkey=/etc/ssl/turn/privkey.pem

# --- Authentication ---
fingerprint
lt-cred-mech
use-auth-secret
static-auth-secret=${TURN_SECRET}
realm=matrix.mamood.ir

# --- NAT traversal ---
# Replace with your actual public IP if not using STUN-based auto-detection
# external-ip=YOUR_PUBLIC_IP

# --- Security: block RFC-1918 ranges so TURN can't be used to probe LAN ---
no-multicast-peers
denied-peer-ip=10.0.0.0-10.255.255.255
denied-peer-ip=172.16.0.0-172.31.255.255
denied-peer-ip=192.168.0.0-192.168.255.255
denied-peer-ip=100.64.0.0-100.127.255.255
denied-peer-ip=169.254.0.0-169.254.255.255
denied-peer-ip=::1
denied-peer-ip=fe80::/10
denied-peer-ip=fc00::/7

# --- Logging ---
log-file=stdout
