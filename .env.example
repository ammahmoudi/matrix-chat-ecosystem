# Root environment variables for docker-compose.yml
# Copy to .env and fill with real values.

# Postgres
POSTGRES_USER=client
POSTGRES_PASSWORD=change_me
POSTGRES_DB=matrix

# Domains (replace example.com with your actual domain)
PUSH_DOMAIN=push.example.com
MAS_ADMIN_MAS_BASE_URL=https://auth.example.com
MAS_ADMIN_REDIRECT_BASE=https://matrix.example.com
MAS_ADMIN_CHAT_BASE_URL=https://chat.example.com
