# Root environment variables for docker-compose.yml
# Copy to .env and fill with real values.

# Postgres
POSTGRES_USER=client
POSTGRES_PASSWORD=change_me
POSTGRES_DB=matrix

# Domains (replace example.com with your actual domain)
PUSH_DOMAIN=push.example.com
MAS_ADMIN_MAS_BASE_URL=https://auth.example.com
MAS_ADMIN_CLIENT_ID=00000000000000000000000007
MAS_ADMIN_REDIRECT_BASE=https://matrix.example.com
MAS_ADMIN_CHAT_BASE_URL=https://chat.example.com

# --- Voice & Video Calls ---

# LiveKit SFU — API key (any short identifier, e.g. your project name)
LIVEKIT_KEY=mamood

# LiveKit SFU — API secret (generate with: openssl rand -hex 32)
LIVEKIT_SECRET=change_me

# coturn TURN server — shared secret (generate with: openssl rand -hex 32)
# Must also be set in synapse/homeserver.yaml under turn_shared_secret
TURN_SECRET=change_me
